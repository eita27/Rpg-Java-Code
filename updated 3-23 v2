// ================= MAGE =================
class Mage extends Character {
    int mana;

    Mage(String name) {
        super(name, "Mage", 160, 25, 50);
        mana = 50;
    }

    @Override
    void lightAttack(Character enemy) {
        if (mana < 3) {
            System.out.println("Not enough mana!");
            return;
        }
        mana -= 3;
        super.lightAttack(enemy);
        System.out.println("Mana left: " + mana);
    }

    @Override
    void heavyAttack(Character enemy) {
        if (mana < 6) {
            System.out.println("Not enough mana!");
            return;
        }
        mana -= 6;
        super.heavyAttack(enemy);
        System.out.println("Mana left: " + mana);
    }

    @Override
    String getResourceDisplay() {
        return "Stamina: " + stamina + " | Mana: " + mana;
    }
}

