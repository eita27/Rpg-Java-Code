// ================= ENEMY =================
class Enemy extends Character {

    Enemy(String name, int health, int damage) {
        super(name, "Enemy", health, damage, 10);
    }

    void enemyAttack(Character player) {
        if (rand.nextBoolean()) {
            lightAttack(player);
        } else {
            heavyAttack(player);
        }
    }
}

// ================= MAIN =================
public class Main {

    static Scanner input = new Scanner(System.in);

    // ---------- STORY ----------
    public static void storyIntro() {
        System.out.println("\n=== PROLOGUE ===");
        System.out.println("You awaken in a strange land...");
        System.out.println("A floating companion greets you.");
        System.out.println("\"Hey! You're finally awake!\"");
        System.out.println("You arrive in MONDSTADT, the City of Freedom.");
        System.out.println("But a dragon—DVALIN—is attacking!");
        System.out.println("You decide to help...\n");
    }

    public static void storyBeforeEnemy(int index, Enemy enemy) {
        System.out.println("\n=== STORY ===");

        switch (index) {
            case 0:
                System.out.println("Slimes bounce toward you!");
                break;
            case 1:
                System.out.println("Hilichurls are causing trouble nearby.");
                break;
            case 2:
                System.out.println("A Lawachurl blocks your path.");
                break;
            case 3:
                System.out.println("An Abyess Mage appears...");
                break;
            case 4:
                System.out.println("A Ruin Guard awakens!");
                break;
            case 5:
                System.out.println("FINAL BATTLE: DVALIN, THE STORMTERROR!");
                break;
        }

        System.out.println("\nA wild " + enemy.name + " appeared!");
    }

    public static void storyEnding(boolean win) {
        System.out.println("\n=== EPILOGUE ===");

        if (win) {
            System.out.println("Dvalin is freed. Peace returns to Mondstadt.");
        } else {
            System.out.println("You were defeated... but your journey continues.");
        }
    }

    // ---------- GAME ----------
    public static Character chooseClass() {

        System.out.println("Choose your class:");
        System.out.println("1. Archer");
        System.out.println("2. Assassin");
        System.out.println("3. Mage");
        System.out.println("4. Knight");
        System.out.print("Choice: ");

        int choice = input.nextInt();

        System.out.print("Enter your name: ");
        String name = input.next();

        switch (choice) {
            case 1: return new Archer(name);
            case 2: return new Assassin(name);
            case 3: return new Mage(name);
            case 777: return new Seraphim(name);
            default: return new Knight(name);
        }
    }

    public static Enemy[] createEnemies() {
        return new Enemy[] {
            new Enemy("Slime", 30, 4),
            new Enemy("Hilichurl", 40, 8),
            new Enemy("Lawachurl", 60, 10),
            new Enemy("Abyss Mage", 80, 12),
            new Enemy("Ruin Guard", 100, 14),
            new Enemy("STORMTERROR DVALIN", 150, 18)
        };
    }

    public static void battle(Character player, Enemy enemy, int index) {

        storyBeforeEnemy(index, enemy);

        while (player.isAlive() && enemy.isAlive()) {

            player.gainStamina();
            enemy.gainStamina();

            System.out.println("\n" + player.name + " (" + player.job + ")");
            System.out.println("HP: " + player.health + " | " + player.getResourceDisplay());
            System.out.println(enemy.name + " HP: " + enemy.health);

            System.out.println("1. Light Attack");
            System.out.println("2. Heavy Attack");
            System.out.print("Choice: ");

            int action = input.nextInt();

            if (action == 1) player.lightAttack(enemy);
            else player.heavyAttack(enemy);

            if (enemy.isAlive()) {
                enemy.enemyAttack(player);
            }
        }

        if (!player.isAlive()) {
            System.out.println("You were defeated...");
        } else {
            System.out.println("Enemy defeated!");
        }
    }

    public static void main(String[] args) {

        boolean playing = true;

        while (playing) {

            storyIntro();

            Character player = chooseClass();
            Enemy[] enemies = createEnemies();

            boolean survivedAll = true;

            for (int i = 0; i < enemies.length; i++) {

                battle(player, enemies[i], i);

                if (!player.isAlive()) {
                    survivedAll = false;
                    break;
                }
            }

            storyEnding(survivedAll);

            System.out.println("\n1. Restart Game");
            System.out.println("2. Exit");

            int choice = input.nextInt();

            if (choice != 1) playing = false;
        }

        System.out.println("Game closed.");
    }
}
