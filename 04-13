import java.util.*;

// ================= ABSTRACT CHARACTER =================
abstract class Character {
    String name, job;
    int health, damage, stamina;
    Random rand = new Random();

    Character(String name, String job, int health, int damage, int stamina) {
        this.name = name;
        this.job = job;
        this.health = health;
        this.damage = damage;
        this.stamina = stamina;
    }

    boolean isAlive() {
        return health > 0;
    }

    void gainStamina() {
        stamina += 5;
    }

    // 🔥 ABSTRACT METHODS
    abstract void lightAttack(Character enemy);
    abstract void heavyAttack(Character enemy);
    abstract String getResourceDisplay();

    // 🔥 SHARED DAMAGE LOGIC
    protected int calculateLightDamage(int critChance) {
        int min = (int)(damage * 0.8);
        int max = (int)(damage * 1.2);
        int dmg = rand.nextInt(max - min + 1) + min;

        if (rand.nextInt(100) < critChance) {
            dmg *= 2;
            System.out.println("CRITICAL HIT!");
        }

        return dmg;
    }

    protected int calculateHeavyDamage(int critChance) {
        int base = damage * 2;
        int min = (int)(base * 0.9);
        int max = (int)(base * 1.5);
        int dmg = rand.nextInt(max - min + 1) + min;

        if (rand.nextInt(100) < critChance) {
            dmg *= 2;
            System.out.println("CRITICAL HEAVY HIT!");
        }

        return dmg;
    }
}

// ================= ARCHER =================
class Archer extends Character {
    int arrows = 20;

    Archer(String name) {
        super(name, "Archer", 170, 20, 25);
    }

    @Override
    void lightAttack(Character enemy) {
        if (arrows <= 0 || stamina < 5) {
            System.out.println("Not enough resources!");
            return;
        }

        stamina -= 5;
        arrows--;

        int dmg = calculateLightDamage(20);
        enemy.health -= dmg;

        System.out.println(name + " shot an arrow for " + dmg + " damage!");
        System.out.println("Arrows left: " + arrows);
    }

    @Override
    void heavyAttack(Character enemy) {
        if (arrows < 2 || stamina < 10) {
            System.out.println("Not enough resources!");
            return;
        }

        stamina -= 10;
        arrows -= 2;

        int dmg = calculateHeavyDamage(30);
        enemy.health -= dmg;

        System.out.println(name + " fired a POWER SHOT for " + dmg + " damage!");
        System.out.println("Arrows left: " + arrows);
    }

    @Override
    String getResourceDisplay() {
        return "Stamina: " + stamina + " | Arrows: " + arrows;
    }
}

