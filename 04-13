// ================= SERAPHIM (SECRET CLASS) =================
class Seraphim extends Character {

    Seraphim(String name) {
        super(name, "Seraphim", Integer.MAX_VALUE, 1000, Integer.MAX_VALUE);
    }

    @Override
    boolean isAlive() {
        return true;
    }

    @Override
    void gainStamina() {}

    @Override
    void lightAttack(Character enemy) {
        int dmg = damage;
        if (rand.nextInt(100) < 50) {
            dmg *= 2;
            System.out.println("DIVINE LIGHT!");
        }
        enemy.health -= dmg;
        System.out.println(name + " smites for " + dmg + " damage!");
    }

    @Override
    void heavyAttack(Character enemy) {
        int dmg = damage * 2;
        if (rand.nextInt(100) < 70) {
            dmg *= 2;
            System.out.println("HEAVENLY JUDGMENT!");
        }
        enemy.health -= dmg;
        System.out.println(name + " unleashes FINAL JUDGMENT for " + dmg + " damage!");
    }

    @Override
    String getResourceDisplay() {
        return "Divinity: ∞";
    }
}

// ================= ENEMY =================
class Enemy extends Character {

    Enemy(String name, int health, int damage) {
        super(name, "Enemy", health, damage, 10);
    }

    @Override
    void lightAttack(Character player) {
        int dmg = calculateLightDamage(15);
        player.health -= dmg;
        System.out.println(name + " attacks for " + dmg);
    }

    @Override
    void heavyAttack(Character player) {
        int dmg = calculateHeavyDamage(20);
        player.health -= dmg;
        System.out.println(name + " uses heavy attack for " + dmg);
    }

    @Override
    String getResourceDisplay() {
        return "";
    }

    void act(Character player) {
        if (rand.nextBoolean()) lightAttack(player);
        else heavyAttack(player);
    }
}

// ================= MAIN =================
public class Main {

    static Scanner input = new Scanner(System.in);

    static Character chooseClass() {
        System.out.println("1. Archer\n2. Assassin\n3. Mage\n4. Knight");
        int choice = input.nextInt();

        System.out.print("Name: ");
        String name = input.next();

        switch (choice) {
            case 1: return new Archer(name);
            case 2: return new Assassin(name);
            case 3: return new Mage(name);
            case 777: return new Seraphim(name);
            default: return new Knight(name);
        }
    }

    static void battle(Character player, Enemy enemy) {
        System.out.println("\nA wild " + enemy.name + " appears!");

        while (player.isAlive() && enemy.isAlive()) {

            player.gainStamina();
            enemy.gainStamina();

            System.out.println("\n" + player.name + " HP: " + player.health + " | " + player.getResourceDisplay());
            System.out.println(enemy.name + " HP: " + enemy.health);

            System.out.println("1. Light\n2. Heavy");
            int action = input.nextInt();

            if (action == 1) player.lightAttack(enemy);
            else player.heavyAttack(enemy);

            if (enemy.isAlive()) enemy.act(player);
        }

        System.out.println(player.isAlive() ? "Victory!" : "Defeat...");
    }

    public static void main(String[] args) {

        Character player = chooseClass();

        Enemy[] enemies = {
            new Enemy("Slime", 30, 4),
            new Enemy("Hilichurl", 40, 8),
            new Enemy("Boss", 80, 12)
        };

        for (Enemy e : enemies) {
            battle(player, e);
            if (!player.isAlive()) break;
        }

        System.out.println("Game Over.");
    }
}
